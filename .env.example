# --- Database ---
DB_URL=postgresql+asyncpg://knicksiq:knicksiq@localhost:5432/knicksiq
DB_ECHO=false
DB_POOL_SIZE=5

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
APP_NAME=knicksiq-api
ENVIRONMENT=development
DEBUG=true
TEST_MODE=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# --- AI / RAG model provider ---
AI_PROVIDER=mock
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_REQUEST_TIMEOUT_SECONDS=20
#
# OpenRouter example:
# AI_PROVIDER=openrouter
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=
# AI_CHAT_MODEL=poolside/laguna-xs-2.1:free

# --- Embeddings (Phase 5+) ---
SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- NBA data source (Phase 8) ---
# "static" (JSON seed files) or "nba_api" (live NBA.com API via swar/nba_api)
NBA_DATA_SOURCE=static
NBA_API_SEASONS=2021-22,2022-23,2023-24,2024-25,2025-26
NBA_API_TIMEOUT_SECONDS=30
NBA_API_PROXY=
NBA_API_RATE_REMAINING_MINUTES=10
NBA_API_USER_AGENT=KnicksIQ/0.1 (sports analytics)
NBA_API_RETRY_ATTEMPTS=3
NBA_API_RETRY_BACKOFF_SECONDS=2.0
