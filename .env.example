# --- Database ---
DB_URL=postgresql+asyncpg://knicksiq:knicksiq@localhost:5432/knicksiq
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=5
DB_STATEMENT_TIMEOUT_MS=3000

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
# Generate a unique value for each non-local environment.
IP_HASH_SECRET=

# --- App ---
APP_NAME=knicksiq-api
ENVIRONMENT=development
DEBUG=true
TEST_MODE=false
SEED_ON_STARTUP=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
TRUSTED_HOSTS=["localhost","127.0.0.1","test"]
PUBLIC_WEB_ORIGIN=http://localhost:5173

# --- AI / RAG model provider ---
AI_PROVIDER=openrouter
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_REQUEST_TIMEOUT_SECONDS=2.5
OPENROUTER_API_KEY=
OPENROUTER_SUMMARY_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_ALLOWED_MODELS=["nvidia/nemotron-3-ultra-550b-a55b:free"]
OPENROUTER_MONTHLY_CUTOFF_USD=8
RAG_LLM_PLANNER_ENABLED=true
RAG_RERANKER_ENABLED=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=0.5
RAG_QDRANT_ENABLED=false
RAG_QDRANT_CLOUD_INFERENCE=false
RAG_HYBRID_ENABLED=false
ANALYSIS_ANSWER_MODE=deterministic
ANALYSIS_SHADOW_SAMPLE_RATE=0.1
ANALYSIS_PROMPT_VERSION=v1

# --- Error monitoring (no replay; request data is scrubbed) ---
SENTRY_DSN=

# --- Local/offline embeddings (not installed in the production API image) ---
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_DEVICE=
RAG_EMBEDDING_BATCH_SIZE=64
RAG_EMBEDDING_MAX_SEQ_LENGTH=128

# --- NBA data source (Phase 8) ---
# "static" (JSON seed files) or "nba_api" (live NBA.com API via swar/nba_api)
NBA_DATA_SOURCE=static
NBA_API_SEASONS=2021-22,2022-23,2023-24,2024-25,2025-26
NBA_API_TIMEOUT_SECONDS=30
NBA_API_RATE_REMAINING_MINUTES=10
NBA_API_USER_AGENT=KnicksIQ/0.1 (sports analytics)
NBA_API_RETRY_ATTEMPTS=3
NBA_API_RETRY_BACKOFF_SECONDS=2.0
